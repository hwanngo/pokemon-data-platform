# Pokémon Data Platform — environment configuration.
# Copy to `.env` (`cp .env.example .env`) and adjust. `.env` is gitignored.
# `make start` reads this via `--env-file .env`.

# ─── Host ports (change to avoid conflicts on your machine) ──────────────────
APP_PORT=8000
AIRFLOW_PORT=8080
STREAMLIT_PORT=8501

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pokemon_data

# ─── Application / PokéAPI ingestion ─────────────────────────────────────────
API_BASE_URL=https://pokeapi.co/api/v2
API_RATE_LIMIT=20
# Concurrent detail fetches (the mirror is network-bound; raise to go faster).
API_CONCURRENCY=8
LOG_LEVEL=INFO

# ─── Airflow security ────────────────────────────────────────────────────────
# Leave these blank — `make start` generates fresh random values into your local
# .env. If you create .env by hand, fill them in (NEVER commit real secrets):
#   AIRFLOW_FERNET_KEY:  python3 -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
#   AIRFLOW_JWT_SECRET:  openssl rand -hex 32
AIRFLOW_FERNET_KEY=
AIRFLOW_JWT_SECRET=
AIRFLOW_BASE_URL=http://localhost:8080

# ─── Airflow admin user (created by airflow-init) ────────────────────────────
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
